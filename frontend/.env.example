# ─────────────────────────────────────────────────────────────────────────
# STROIK Frontend — Environment variables
# Copy to `.env.local` (do NOT commit) and adjust if needed.
# ─────────────────────────────────────────────────────────────────────────

# Base URL of the FastAPI backend (no trailing slash).
# Local dev: http://127.0.0.1:8000
# Production: https://api.stroik.app
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# App display name (overrides default in PWA manifest)
NEXT_PUBLIC_APP_NAME=СТРОИК
