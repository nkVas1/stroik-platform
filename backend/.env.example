# ─────────────────────────────────────────────────────────────────────────
# STROIK Backend — Environment variables
# Copy to `.env` (do NOT commit) and fill in real values.
# ─────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────
DEBUG=True
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000

# ── Database ──────────────────────────────────────────────────────────
# Local development (SQLite, файл в backend/stroik.db):
DATABASE_URL=sqlite+aiosqlite:///./stroik.db
# Production (PostgreSQL — пример):
# DATABASE_URL=postgresql+asyncpg://stroik:stroik_password@db:5432/stroik_db

# ── Security / JWT ────────────────────────────────────────────────────
# Сгенерируй случайно: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
SECRET_KEY=dev-only-secret-key-CHANGE-ME-in-production
ALGORITHM=HS256
# 7 дней (60 * 24 * 7). Уменьши для production.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── LLM ───────────────────────────────────────────────────────────────
# Если переменная пуста — Gemini не используется, всё работает на локальной Llama3.
# Получить бесплатный ключ: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Локальная LLM (Ollama). Запусти `ollama serve` + `ollama pull llama3`.
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://127.0.0.1:11434

# ── CORS ──────────────────────────────────────────────────────────────
# Разрешённые источники для фронтенда (через запятую).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Uploads ───────────────────────────────────────────────────────────
# Папка для сохранения паспортов и фото-портфолио.
# UPLOADS_DIR=./uploads
